# Provider mode:
# mock | massive-contracts | massive-snapshot-delayed | massive-snapshot-realtime
GEX_DATA_PROVIDER=mock
# Massive API key
MASSIVE_API_KEY=
# Default symbol
DEFAULT_SYMBOL=SPY
# Optional default favorites
DEFAULT_FAVORITES=SPY,QQQ,AAPL,NVDA,TSLA
# Massive API budget
MASSIVE_MAX_CALLS_PER_MINUTE=5
# Server provider refresh interval
SERVER_REFRESH_SECONDS=15
# Frontend local API polling interval
NEXT_PUBLIC_FRONTEND_REFRESH_SECONDS=15
# Cache settings
CACHE_TTL_SECONDS=15
STALE_CACHE_TTL_SECONDS=300
TICKER_SEARCH_CACHE_TTL_SECONDS=86400
OPTIONABLE_CACHE_TTL_SECONDS=86400
# Snapshot pagination
MASSIVE_PAGE_LIMIT=250
MASSIVE_MAX_PAGES_PER_REFRESH=4
# Default options analytics scope
DEFAULT_EXPIRATION_SCOPE=0dte
DEFAULT_STRIKE_WINDOW_PERCENT=8
# Favorites and recent symbols
MAX_FAVORITES=50
MAX_RECENT_SYMBOLS=20
# Feature flags
ENABLE_FLOW_PROXY=true
ENABLE_DARKPOOL_PLACEHOLDER=false
ENABLE_HISTORICAL_STORAGE=false
ENABLE_SCANNER=true
